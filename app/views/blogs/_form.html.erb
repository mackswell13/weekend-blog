<div class="block p-6 m-4 w-full bg-white rounded-lg border border-gray-200 shadow-sm">

  <%= form_with model: blog do |form| %>
    <div class="flex flex-col gap-y-2">
      <%= form.label :title %>
      <%= form.text_field :title, class: "py-1 px-1 rounded-sm border border-[#bbb]" %>

      <%= form.label :content %>
      <%= form.rich_textarea :content %>
    </div>

    <%= form.submit class: "p-2 mt-2 text-white bg-blue-600 rounded-lg" %>
  <% end %>
</div>
