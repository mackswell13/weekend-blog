<h1>Welcome to My Site!</h1>

<% if @is_admin %>
  <%= turbo_frame_tag "create-blog" do %>
    <%= link_to "Create Blog", new_blog_path %>
    <% end %>
<% end %>

<% if @blogs.length > 0 %>
  <h2><%= link_to "Recent Blog Posts", blogs_path %></h2>
  <div class="grid gap-4 lg:grid-cols-3 sm:grid-cols-1">
    <%= render @blogs %>
  </div>
<% end %>
