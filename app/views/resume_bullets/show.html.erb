<h1><%= @resume_bullet.job_title %></h1>
<div><%= @resume_bullet.content %></div>

<% if @is_admin %>
  <div class="flex flex-row gap-4">
    <%= button_to "Delete", @resume_bullet, method: :delete, data: { turbo_confirm: "Are you sure?" }, class: "bg-red-500 rounded-sm px-4 py-2 text-white cursor-pointer" %>
    <%= link_to "Edit", edit_resume_bullet_path(@resume_bullet), class: "bg-blue-500 rounded-sm px-4 py-2 text-white cursor-pointer" %>
  </div>
<% end %>
